# =========================================================================
#                    ANCHORVAULT NETWORK & CONTRACTS ENV
# =========================================================================

# --- CASPER NETWORK CONFIGURATION ---
# Target network: 'casper-test' or 'casper'
CASPER_NETWORK_NAME=casper-test

# Casper Node RPC Endpoint
CASPER_NODE_URL=http://136.243.187.84:7777/rpc

# --- DEPLOYER / ADMIN WALLET CONFIGURATION ---
# The Casper account that deploys the contracts and manages whitelists
CASPER_PUBLIC_KEY="your_casper_public_key"
CASPER_ACCOUNT_HASH="your_casper_account_hash"
CASPER_SECRET_KEY_PATH="./secret_key.pem"

# --- DEPLOYED DEFI CONTRACT ADDRESSES (CASPER HASHES) ---
# Populated after running deploy.js
CASPER_USDC_CONTRACT_HASH="103fcc98fd1eb7fcd3c204683d4ff438665dcd33b486564cd46cc90d6db7344f"
CASPER_VAULT_GOVERNANCE_TOKEN_HASH="25b57f2e9e9786f0abeb990c4329338d8292f7ef9d571fb35f8db5f650b8d6c5"
CASPER_ANCHOR_REGISTRY_CONTRACT_HASH="39871211df19ae9474be579ebbf695589d544ae7ef60243fbe2554d3d686eed7"
CASPER_CORRIDOR_POOL_VAULT_HASH="814117b2cb4f5b63a8ba1f5abb0bbfd11b576fd2b7bbaf23a101b74dbbbfeb4c"

# --- TRANSACTION CONFIGURATION ---
# Notice period for LP high-utilization withdrawals (in seconds, e.g. 172800 = 48 hours)
WITHDRAWAL_NOTICE_WINDOW=172800

# --- AI RISK COPILOT CONFIGURATION ---
# Saved Google Gemini API Key for deep risk reasoning
VITE_GEMINI_API_KEY="your_google_gemini_key_here"
VITE_RESEND_API_KEY="your_resend_api_key_here"

